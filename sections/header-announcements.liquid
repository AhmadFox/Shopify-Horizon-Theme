{%- liquid
  assign page_type = request.page_type | default: template.name
  assign show_announcement_bar = false

  case page_type
    when 'index'
      assign show_announcement_bar = section.settings.show_on_home
    when 'list-collections'
      assign show_announcement_bar = section.settings.show_on_collection_list
    when 'collection'
      assign show_announcement_bar = section.settings.show_on_collection
    when 'product'
      assign show_announcement_bar = section.settings.show_on_product
    else
      assign show_announcement_bar = section.settings.show_on_other
  endcase

  # Always render in the theme editor so merchants can edit while toggles are off.
  if request.design_mode
    assign show_announcement_bar = true
  endif
-%}

{%- if show_announcement_bar -%}
{% render 'contrast-override', background_color: section.settings.background_color, section_id: section.id %}

{%- liquid
  # Keep existing speed (2–10s) as a duration control: higher = slower loop.
  assign marquee_duration = section.settings.speed | times: 6
  assign marquee_gap = 48
  assign separator_icon = section.settings.separator_icon
  assign separator_icon_width = section.settings.separator_icon_width | default: 20
  assign separator_icon_height = section.settings.separator_icon_height | default: 20
  assign has_separator_icon = false
  if separator_icon != blank
    assign has_separator_icon = true
  endif

  # Repeat the message set inside each track so short content still fills the viewport
  # without JS measuring widths (pure CSS marquee).
  assign fill_repeats = 1
  if section.blocks.size == 1
    assign fill_repeats = 4
  elsif section.blocks.size == 2
    assign fill_repeats = 3
  elsif section.blocks.size == 3
    assign fill_repeats = 2
  endif
-%}

{%- capture announcement_items -%}
  {% content_for 'blocks' %}
{%- endcapture -%}

<div class="section-background color-custom-{{ section.id }}"></div>
<aside
  class="
    announcement-bar
    spacing-style
    section
    section--{{ section.settings.section_width }}
    color-custom-{{ section.id }}
    {% if has_separator_icon %}announcement-bar--has-separator{% endif %}
  "
  style="
    {% render 'spacing-padding', settings: section.settings %}
    --border-bottom-width: {{ section.settings.divider_width }}px;
    {% if section.settings.divider_color != blank %}--color-border: {{ section.settings.divider_color }};{% endif %}
    --announcement-marquee-duration: {{ marquee_duration }}s;
    --announcement-gap: {{ marquee_gap }}px;
    --announcement-icon-width: {{ separator_icon_width }}px;
    --announcement-icon-height: {{ separator_icon_height }}px;
  "
  role="region"
  aria-label="{{ 'accessibility.announcements' | t }}"
>
  <div class="announcement-bar__viewport">
    <div class="announcement-bar__track">
      <div class="announcement-bar__group">
        {%- for i in (1..fill_repeats) -%}
          {{ announcement_items }}
        {%- endfor -%}
      </div>

      <div
        class="announcement-bar__group"
        aria-hidden="true"
      >
        {%- for i in (1..fill_repeats) -%}
          {{ announcement_items }}
        {%- endfor -%}
      </div>
    </div>
  </div>
</aside>
{%- endif -%}

{% stylesheet %}
  .announcement-bar {
    border-block-end: var(--border-bottom-width) solid var(--color-border);
    overflow: hidden;
  }

  .announcement-bar__viewport {
    display: block;
    width: 100%;
    overflow: hidden;
  }

  /*
    Force LTR flex geometry on the track so translateX(-50%) is seamless in both
    document directions. Item text direction is restored from the document dir.
  */
  .announcement-bar__track {
    display: flex;
    width: max-content;
    gap: var(--announcement-gap);
    direction: ltr;
    will-change: transform;
  }

  .announcement-bar__group {
    display: flex;
    flex: 0 0 auto;
    align-items: center;
    gap: var(--announcement-gap);
    min-width: max-content;
  }

  /* Restore reading direction for each message (Arabic RTL / English LTR). */
  :root[dir='rtl'] .announcement-bar__item {
    direction: rtl;
    unicode-bidi: isolate;
  }

  :root[dir='ltr'] .announcement-bar__item,
  :root:not([dir]) .announcement-bar__item {
    direction: ltr;
    unicode-bidi: isolate;
  }

  .announcement-bar__item {
    flex: 0 0 auto;
    max-width: none;
  }

  .announcement-bar .announcement-bar__text,
  .announcement-bar .announcement-bar__text * {
    margin: 0;
    white-space: nowrap;
    line-height: 1.2;
    text-wrap: nowrap;
  }

  .announcement-bar__link {
    color: inherit;
    text-decoration: none;
  }

  .announcement-bar__separator {
    display: inline-flex;
    flex: 0 0 auto;
    align-items: center;
    justify-content: center;
    width: var(--announcement-icon-width, 20px);
    height: var(--announcement-icon-height, 20px);
    line-height: 0;
  }

  .announcement-bar__separator-image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  @media (prefers-reduced-motion: no-preference) {
    .announcement-bar__track {
      animation: announcement-marquee var(--announcement-marquee-duration, 30s) linear infinite;
    }

    /* Natural ticker direction: LTR scrolls left, RTL scrolls right. */
    :root[dir='rtl'] .announcement-bar__track {
      animation-direction: reverse;
    }

    .announcement-bar__viewport:hover .announcement-bar__track {
      animation-play-state: paused;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .announcement-bar__track {
      animation: none;
      width: 100%;
      justify-content: center;
    }

    .announcement-bar__group[aria-hidden='true'] {
      display: none;
    }
  }

  @keyframes announcement-marquee {
    to {
      transform: translate3d(calc(-50% - (var(--announcement-gap) / 2)), 0, 0);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.announcement_bar",
  "blocks": [
    {
      "type": "_announcement"
    }
  ],
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:content.visibility"
    },
    {
      "type": "checkbox",
      "id": "show_on_home",
      "label": "t:content.home_page",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_collection_list",
      "label": "t:names.collection_list",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_collection",
      "label": "t:content.collection_page",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_product",
      "label": "t:content.product_page",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_other",
      "label": "t:content.other_pages",
      "default": true
    },
    {
      "type": "range",
      "id": "speed",
      "label": "t:settings.scroll_speed",
      "min": 2,
      "max": 10,
      "default": 5,
      "unit": "sec"
    },
    {
      "type": "header",
      "content": "t:content.icon_between_messages"
    },
    {
      "type": "image_picker",
      "id": "separator_icon",
      "label": "t:settings.icon"
    },
    {
      "type": "range",
      "id": "separator_icon_width",
      "label": "t:settings.width",
      "min": 10,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 20,
      "visible_if": "{{ section.settings.separator_icon != blank }}"
    },
    {
      "type": "range",
      "id": "separator_icon_height",
      "label": "t:settings.height",
      "min": 10,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 20,
      "visible_if": "{{ section.settings.separator_icon != blank }}"
    },
    {
      "type": "header",
      "content": "t:content.appearance"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.section_width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:settings.background_color",
      "placeholder": "t:settings.default"
    },
    {
      "type": "range",
      "id": "divider_width",
      "label": "t:settings.divider_thickness",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "t:settings.divider_color",
      "placeholder": "t:settings.default",
      "visible_if": "{{ section.settings.divider_width > 0 }}"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 15
    }
  ],
  "presets": [
    {
      "name": "t:names.announcement_bar",
      "blocks": {
        "announcement_1": {
          "type": "_announcement"
        }
      },
      "block_order": ["announcement_1"]
    }
  ]
}
{% endschema %}
