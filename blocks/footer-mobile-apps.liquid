{% liquid
  assign block_settings = block.settings
  assign app_store_alt = block_settings.app_store_label | default: 'App Store'
  assign google_play_alt = block_settings.google_play_label | default: 'Google Play'
%}

<div
  class="footer-mobile-apps utilities-apps-item"
  style="
    --apps-gap: {{ block_settings.gap }}px;
    --apps-title-gap: {{ block_settings.title_gap }}px;
    --apps-badge-height: {{ block_settings.badge_height }}px;
    {% render 'utilities-apps-layout-vars', settings: block_settings %}
  "
  {{ block.shopify_attributes }}
>
  {%- if block_settings.heading != blank -%}
    <p
      class="
        footer-mobile-apps__heading
        {{ block_settings.type_preset }}
        {% if block_settings.type_preset == 'custom' %}
          custom-typography
          {% if block_settings.font_size != blank %}custom-font-size{% endif %}
        {% endif %}
      "
      style="
        {% render 'typography-style', settings: block_settings %}
        {% if block_settings.text_color != blank %}
          --color: {{ block_settings.text_color }};
          color: {{ block_settings.text_color }};
        {% endif %}
      "
    >
      {{ block_settings.heading }}
    </p>
  {%- endif -%}

  <div class="footer-mobile-apps__badges">
    {%- capture app_store_badge -%}
      {%- if block_settings.app_store_image != blank -%}
        {{
          block_settings.app_store_image
          | image_url: width: 360
          | image_tag:
            class: 'footer-mobile-apps__badge',
            loading: 'lazy',
            widths: '120, 160, 200, 280, 360',
            sizes: '120px',
            alt: app_store_alt
        }}
      {%- else -%}
        <img
          class="footer-mobile-apps__badge"
          src="{{ 'badge-app-store.png' | asset_url }}"
          alt="{{ app_store_alt | escape }}"
          width="120"
          height="36"
          loading="lazy"
        >
      {%- endif -%}
    {%- endcapture -%}

    {%- if block_settings.app_store_link != blank -%}
      <a
        class="footer-mobile-apps__link"
        href="{{ block_settings.app_store_link }}"
        {% if block_settings.app_store_open_in_new_tab %}
          target="_blank"
          rel="noopener noreferrer"
        {% endif %}
      >
        {{ app_store_badge }}
        <span class="visually-hidden">
          {{ app_store_alt }}
          {%- if block_settings.app_store_open_in_new_tab %} — {{ 'accessibility.new_window' | t }}{% endif -%}
        </span>
      </a>
    {%- else -%}
      <span class="footer-mobile-apps__link footer-mobile-apps__link--static">
        {{ app_store_badge }}
      </span>
    {%- endif -%}

    {%- capture google_play_badge -%}
      {%- if block_settings.google_play_image != blank -%}
        {{
          block_settings.google_play_image
          | image_url: width: 360
          | image_tag:
            class: 'footer-mobile-apps__badge',
            loading: 'lazy',
            widths: '120, 160, 200, 280, 360',
            sizes: '120px',
            alt: google_play_alt
        }}
      {%- else -%}
        <img
          class="footer-mobile-apps__badge"
          src="{{ 'badge-google-play.png' | asset_url }}"
          alt="{{ google_play_alt | escape }}"
          width="120"
          height="36"
          loading="lazy"
        >
      {%- endif -%}
    {%- endcapture -%}

    {%- if block_settings.google_play_link != blank -%}
      <a
        class="footer-mobile-apps__link"
        href="{{ block_settings.google_play_link }}"
        {% if block_settings.google_play_open_in_new_tab %}
          target="_blank"
          rel="noopener noreferrer"
        {% endif %}
      >
        {{ google_play_badge }}
        <span class="visually-hidden">
          {{ google_play_alt }}
          {%- if block_settings.google_play_open_in_new_tab %} — {{ 'accessibility.new_window' | t }}{% endif -%}
        </span>
      </a>
    {%- else -%}
      <span class="footer-mobile-apps__link footer-mobile-apps__link--static">
        {{ google_play_badge }}
      </span>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .footer-mobile-apps {
    --ua-align: var(--ua-align-mobile, center);
    --ua-text: var(--ua-text-mobile, center);
    display: flex;
    flex-direction: column;
    align-items: var(--ua-align);
    gap: var(--apps-title-gap, 8px);
    min-width: 0;
    text-align: var(--ua-text);

    @media screen and (min-width: 750px) {
      --ua-align: var(--ua-align-tablet, var(--ua-align-mobile, center));
      --ua-text: var(--ua-text-tablet, var(--ua-text-mobile, center));
    }

    @media screen and (min-width: 990px) {
      --ua-align: var(--ua-align-desktop, var(--ua-align-tablet, center));
      --ua-text: var(--ua-text-desktop, var(--ua-text-tablet, center));
    }
  }

  .footer-mobile-apps__heading {
    margin: 0;
    width: 100%;
    line-height: 1.3;
    color: var(--color, var(--color-foreground));
    font-family: var(--font-family, inherit);
    font-size: var(--font-size, 1rem);
    font-weight: var(--font-weight, 600);
    letter-spacing: var(--letter-spacing, normal);
    text-transform: var(--text-transform, none);
    text-wrap: var(--text-wrap, pretty);
  }

  .footer-mobile-apps__badges {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: var(--ua-align);
    gap: var(--apps-gap, 8px);
  }

  .footer-mobile-apps__link {
    display: inline-flex;
    line-height: 0;
    text-decoration: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .footer-mobile-apps__link:hover {
    opacity: 0.88;
    transform: translateY(-1px);
  }

  .footer-mobile-apps__link--static {
    cursor: default;
  }

  .footer-mobile-apps__link--static:hover {
    opacity: 1;
    transform: none;
  }

  .footer-mobile-apps__badge {
    display: block;
    width: auto;
    height: auto;
    max-height: var(--apps-badge-height, 36px);
    max-width: 140px;
    object-fit: contain;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.footer_mobile_apps",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:settings.heading",
      "default": "حمل التطبيق"
    },
    {
      "type": "header",
      "content": "t:content.app_store"
    },
    {
      "type": "image_picker",
      "id": "app_store_image",
      "label": "t:settings.image"
    },
    {
      "type": "url",
      "id": "app_store_link",
      "label": "t:settings.link"
    },
    {
      "type": "checkbox",
      "id": "app_store_open_in_new_tab",
      "label": "t:settings.open_new_tab",
      "default": true,
      "visible_if": "{{ block.settings.app_store_link != blank }}"
    },
    {
      "type": "text",
      "id": "app_store_label",
      "label": "t:settings.title",
      "default": "App Store"
    },
    {
      "type": "header",
      "content": "t:content.google_play"
    },
    {
      "type": "image_picker",
      "id": "google_play_image",
      "label": "t:settings.image"
    },
    {
      "type": "url",
      "id": "google_play_link",
      "label": "t:settings.link"
    },
    {
      "type": "checkbox",
      "id": "google_play_open_in_new_tab",
      "label": "t:settings.open_new_tab",
      "default": true,
      "visible_if": "{{ block.settings.google_play_link != blank }}"
    },
    {
      "type": "text",
      "id": "google_play_label",
      "label": "t:settings.title",
      "default": "Google Play"
    },
    {
      "type": "header",
      "content": "t:settings.alignment"
    },
    {
      "type": "select",
      "id": "alignment_mobile",
      "label": "t:options.mobile",
      "options": [
        { "value": "flex-start", "label": "t:options.left" },
        { "value": "center", "label": "t:options.center" },
        { "value": "flex-end", "label": "t:options.right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "alignment_tablet",
      "label": "t:options.tablet",
      "options": [
        { "value": "flex-start", "label": "t:options.left" },
        { "value": "center", "label": "t:options.center" },
        { "value": "flex-end", "label": "t:options.right" }
      ],
      "default": "flex-end"
    },
    {
      "type": "select",
      "id": "alignment_desktop",
      "label": "t:options.desktop",
      "options": [
        { "value": "flex-start", "label": "t:options.left" },
        { "value": "center", "label": "t:options.center" },
        { "value": "flex-end", "label": "t:options.right" }
      ],
      "default": "flex-end"
    },
    {
      "type": "header",
      "content": "t:settings.position"
    },
    {
      "type": "select",
      "id": "position_mobile",
      "label": "t:options.mobile",
      "options": [
        { "value": "flex-start", "label": "t:options.left" },
        { "value": "center", "label": "t:options.center" },
        { "value": "flex-end", "label": "t:options.right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "position_tablet",
      "label": "t:options.tablet",
      "options": [
        { "value": "flex-start", "label": "t:options.left" },
        { "value": "center", "label": "t:options.center" },
        { "value": "flex-end", "label": "t:options.right" }
      ],
      "default": "flex-end"
    },
    {
      "type": "select",
      "id": "position_desktop",
      "label": "t:options.desktop",
      "options": [
        { "value": "flex-start", "label": "t:options.left" },
        { "value": "center", "label": "t:options.center" },
        { "value": "flex-end", "label": "t:options.right" }
      ],
      "default": "flex-end"
    },
    {
      "type": "header",
      "content": "t:content.typography"
    },
    {
      "type": "select",
      "id": "type_preset",
      "label": "t:settings.preset",
      "options": [
        { "value": "paragraph", "label": "t:options.paragraph" },
        { "value": "h1", "label": "t:options.h1" },
        { "value": "h2", "label": "t:options.h2" },
        { "value": "h3", "label": "t:options.h3" },
        { "value": "h4", "label": "t:options.h4" },
        { "value": "h5", "label": "t:options.h5" },
        { "value": "h6", "label": "t:options.h6" },
        { "value": "custom", "label": "t:options.custom" }
      ],
      "default": "custom",
      "info": "t:info.edit_presets_in_theme_settings"
    },
    {
      "type": "select",
      "id": "font",
      "label": "t:settings.font",
      "options": [
        { "value": "var(--font-body--family)", "label": "t:options.body" },
        { "value": "var(--font-subheading--family)", "label": "t:options.subheading" },
        { "value": "var(--font-heading--family)", "label": "t:options.heading" },
        { "value": "var(--font-accent--family)", "label": "t:options.accent" }
      ],
      "default": "var(--font-body--family)",
      "visible_if": "{{ block.settings.type_preset == 'custom' }}"
    },
    {
      "type": "select",
      "id": "font_size",
      "label": "t:settings.size",
      "options": [
        { "value": "0.625rem", "label": "10px" },
        { "value": "0.75rem", "label": "12px" },
        { "value": "0.875rem", "label": "14px" },
        { "value": "1rem", "label": "16px" },
        { "value": "1.125rem", "label": "18px" },
        { "value": "1.25rem", "label": "20px" },
        { "value": "1.5rem", "label": "24px" }
      ],
      "default": "1rem",
      "visible_if": "{{ block.settings.type_preset == 'custom' }}"
    },
    {
      "type": "select",
      "id": "line_height",
      "label": "t:settings.line_height",
      "options": [
        { "value": "tight", "label": "t:options.tight" },
        { "value": "normal", "label": "t:options.normal" },
        { "value": "loose", "label": "t:options.loose" }
      ],
      "default": "normal",
      "visible_if": "{{ block.settings.type_preset == 'custom' }}"
    },
    {
      "type": "select",
      "id": "letter_spacing",
      "label": "t:settings.letter_spacing",
      "options": [
        { "value": "tight", "label": "t:options.tight" },
        { "value": "normal", "label": "t:options.normal" },
        { "value": "loose", "label": "t:options.loose" }
      ],
      "default": "normal",
      "visible_if": "{{ block.settings.type_preset == 'custom' }}"
    },
    {
      "type": "select",
      "id": "case",
      "label": "t:settings.case",
      "options": [
        { "value": "none", "label": "t:options.default" },
        { "value": "uppercase", "label": "t:options.uppercase" }
      ],
      "default": "none",
      "visible_if": "{{ block.settings.type_preset == 'custom' }}"
    },
    {
      "type": "header",
      "content": "t:content.appearance"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:settings.text_color",
      "placeholder": "t:settings.default"
    },
    {
      "type": "range",
      "id": "title_gap",
      "label": "t:settings.vertical_gap",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:settings.gap",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "badge_height",
      "label": "t:settings.height",
      "min": 24,
      "max": 56,
      "step": 1,
      "unit": "px",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "t:names.footer_mobile_apps",
      "category": "t:categories.footer"
    }
  ]
}
{% endschema %}
