{% liquid
  assign block_settings = block.settings
  assign tax_label = block_settings.tax_number_label
  assign cr_label = block_settings.commercial_register_label

  if tax_label == blank
    assign tax_label = 'sections.footer_trust.tax_number' | t
  endif

  if cr_label == blank
    assign cr_label = 'sections.footer_trust.commercial_register' | t
  endif
%}

<div
  class="
    footer-credentials
    utilities-apps-item
    custom-typography
    {% if block_settings.font_size != blank %}custom-font-size{% endif %}
  "
  style="
    --cred-gap: {{ block_settings.gap }}px;
    --cred-title-gap: {{ block_settings.title_gap }}px;
    --cred-badge-height: {{ block_settings.badge_height }}px;
    --cred-font-size: {{ block_settings.font_size }};
    --cred-text-case: {{ block_settings.case }};
    {% if block_settings.text_color != blank %}--cred-text-color: {{ block_settings.text_color }};{% endif %}
    {% render 'utilities-apps-layout-vars', settings: block_settings %}
  "
  {{ block.shopify_attributes }}
>
  {%- if block_settings.tax_number != blank or block_settings.commercial_register != blank -%}
    <dl class="footer-credentials__details">
      {%- if block_settings.tax_number != blank -%}
        <div class="footer-credentials__detail">
          <dt>{{ tax_label }}</dt>
          <dd>{{ block_settings.tax_number }}</dd>
        </div>
      {%- endif -%}

      {%- if block_settings.commercial_register != blank -%}
        <div class="footer-credentials__detail">
          <dt>{{ cr_label }}</dt>
          <dd>{{ block_settings.commercial_register }}</dd>
        </div>
      {%- endif -%}
    </dl>
  {%- endif -%}

  <div class="footer-credentials__badges">
    {%- for i in (1..5) -%}
      {%- liquid
        assign image_key = 'image_' | append: i
        assign link_key = 'link_' | append: i
        assign title_key = 'title_' | append: i
        assign new_tab_key = 'open_in_new_tab_' | append: i
        assign cred_image = block_settings[image_key]
        assign cred_link = block_settings[link_key]
        assign cred_title = block_settings[title_key]
        assign cred_new_tab = block_settings[new_tab_key]
        assign fallback_asset = ''
        assign badge_class = 'footer-credentials__badge'

        case i
          when 1
            assign fallback_asset = 'badge-saudi-business-center.png'
            if cred_title == blank
              assign cred_title = 'Saudi Business Center'
            endif
          when 2
            assign fallback_asset = 'badge-saudi-made.png'
            if cred_title == blank
              assign cred_title = 'Saudi Made'
            endif
          when 3
            assign fallback_asset = 'badge-vision-2030.png'
            if cred_title == blank
              assign cred_title = 'Vision 2030'
            endif
          when 4
            assign fallback_asset = 'badge-store-qr.png'
            assign badge_class = badge_class | append: ' footer-credentials__badge--qr'
            if cred_title == blank
              assign cred_title = 'sections.footer_trust.store_qr' | t
            endif
          when 5
            assign fallback_asset = 'badge-vat-ksa.png'
            assign badge_class = badge_class | append: ' footer-credentials__badge--vat'
            if cred_title == blank
              assign cred_title = 'VAT'
            endif
        endcase
      -%}

      {%- capture cred_badge -%}
        {%- if cred_image != blank -%}
          {{
            cred_image
            | image_url: width: 240
            | image_tag:
              class: badge_class,
              loading: 'lazy',
              widths: '64, 96, 128, 180, 240',
              sizes: '56px',
              alt: cred_title
          }}
        {%- else -%}
          <img
            class="{{ badge_class }}"
            src="{{ fallback_asset | asset_url }}"
            alt="{{ cred_title | escape }}"
            width="56"
            height="56"
            loading="lazy"
          >
        {%- endif -%}
      {%- endcapture -%}

      {%- if cred_link != blank -%}
        <a
          class="footer-credentials__link"
          href="{{ cred_link }}"
          {% if cred_new_tab %}
            target="_blank"
            rel="noopener noreferrer"
          {% endif %}
        >
          {{ cred_badge }}
          <span class="visually-hidden">
            {{ cred_title }}
            {%- if cred_new_tab %} — {{ 'accessibility.new_window' | t }}{% endif -%}
          </span>
        </a>
      {%- else -%}
        <span class="footer-credentials__link footer-credentials__link--static">
          {{ cred_badge }}
        </span>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
  .footer-credentials {
    --ua-align: var(--ua-align-mobile, flex-start);
    --ua-text: var(--ua-text-mobile, start);
    display: flex;
    flex-direction: column;
    align-items: var(--ua-align);
    gap: var(--cred-title-gap, 10px);
    min-width: 0;
    text-align: var(--ua-text);

    @media screen and (min-width: 750px) {
      --ua-align: var(--ua-align-tablet, var(--ua-align-mobile, flex-start));
      --ua-text: var(--ua-text-tablet, var(--ua-text-mobile, start));
    }

    @media screen and (min-width: 990px) {
      --ua-align: var(--ua-align-desktop, var(--ua-align-tablet, flex-start));
      --ua-text: var(--ua-text-desktop, var(--ua-text-tablet, start));
    }
  }

  .footer-credentials__details {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin: 0;
    font-size: var(--cred-font-size, 0.6875rem);
    line-height: 1.35;
    width: 100%;
    text-align: var(--ua-text);
    text-transform: var(--cred-text-case, none);
    color: var(--cred-text-color, var(--color-foreground-muted));
  }

  .footer-credentials__detail {
    display: flex;
    flex-wrap: wrap;
    justify-content: var(--ua-align);
    gap: 0.3em;
  }

  .footer-credentials__detail dt {
    margin: 0;
    font-weight: 600;
    color: var(--cred-text-color, var(--color-foreground));
  }

  .footer-credentials__detail dd {
    margin: 0;
    font-variant-numeric: tabular-nums;
  }

  .footer-credentials__details a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .footer-credentials__badges {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: var(--ua-align);
    gap: var(--cred-gap, 10px);
  }

  .footer-credentials__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    line-height: 0;
    text-decoration: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .footer-credentials__link:hover {
    opacity: 0.88;
    transform: translateY(-1px);
  }

  .footer-credentials__link--static {
    cursor: default;
  }

  .footer-credentials__link--static:hover {
    opacity: 1;
    transform: none;
  }

  .footer-credentials__badge {
    display: block;
    width: auto;
    height: auto;
    max-width: 56px;
    max-height: var(--cred-badge-height, 52px);
    object-fit: contain;
  }

  .footer-credentials__badge--qr {
    max-width: 48px;
    background: #fff;
    border-radius: 3px;
    padding: 2px;
  }

  .footer-credentials__badge--vat {
    max-width: 44px;
  }
{% endstylesheet %}

